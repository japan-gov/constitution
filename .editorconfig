# ============================================================
#  .editorconfig — 帝国議会内部規則
#
#  Art.51: 「両議院ハ…内部ノ整理ニ必要ナル諸規則ヲ定ムルコトヲ得」
#
#  本書ハ帝国議会ガ自主的ニ定メタル唯一ノ権限ノ産物ナリ。
#  議員ニ許サレタル数少ナキ自治権ノ一ツ。
#
#  ⚠️ 但シ本規則ハ勅命ニ依リ何時ニテモ上書キ可能。
# ============================================================

root = true
# root = true: 此レヨリ上位ノ .editorconfig ハ参照セズ。
# 天皇陛下ガ root ナレバ、設定ファイルモ root ナリ。

# ============================================================
#  全ファイル共通（帝国標準）
# ============================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
# 末尾ノ空白ハ除去ス。無駄ハ帝国ニ不要ナリ。

indent_style = space
indent_size = 2
# 2空白。Tab ハ不敬罪。

# ============================================================
#  TypeScript / JavaScript（帝国法令）
# ============================================================
[*.{ts,js}]
indent_size = 2
quote_type = double
# 二重引用符ヲ使用ス。一重引用符ハ臣民ノ略式ナリ。

max_line_length = 120
# 1行120桁。勅令ハ簡潔ニ。然レドモ憲法条文ハ例外トス。

# ============================================================
#  YAML（大臣人事設定 等）
# ============================================================
[*.{yaml,yml}]
indent_size = 2
# kubectl apply -f ministers.yaml ニ備ヘヨ。

# ============================================================
#  JSON（package.json 等）
# ============================================================
[*.json]
indent_size = 2
insert_final_newline = false
# JSON ハ末尾改行不要。npm ノ仕様ニ従フ。

# ============================================================
#  Markdown（勅語・布告文書）
# ============================================================
[*.md]
trim_trailing_whitespace = false
# Markdown ノ末尾空白ハ改行ヲ意味ス。
# 天皇陛下ノ御言葉ノ改行ヲ削除スルハ不敬罪。

max_line_length = off
# 勅語ニ文字数制限ハ無シ。

# ============================================================
#  HTML（Imperial Console）
# ============================================================
[*.html]
indent_size = 2

# ============================================================
#  憲法条文データ（特別規則）
# ============================================================
[src/constitution/*.ts]
max_line_length = off
# 不磨ノ大典ニ行幅制限ヲ課スハ不敬ナリ。
# Object.freeze() 済ミ。reformatting 不可。

# ============================================================
#  皇室典範（別典）
# ============================================================
[src/imperial-house.ts]
max_line_length = off
# 憲法ト同格ノ別典。同ジク行幅制限ヲ免除ス。

# ============================================================
#  NOTE: 帝国議会ニ許サレタル自治権ハ此処マデ。
#        其ノ他ノ事項ハ天皇陛下ノ勅命ニ依ル。
# ============================================================
